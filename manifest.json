
{
    "manifest_version": 3,
    "name": "Comments Finder",
    "description": "Finds comments in the current page, currently only html.",
    "homepage_url": "https://github.com/aRandomMenno/CommentFinder",
    "version": "r0.4",
    "permissions": [
        "activeTab"
    ],
    "host_permissions": [
        "*://*/*"
    ],
    "background": {
        "page": "backgroundScript.html"
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "CommentFinder@aRandomMenno.github.io"
        }
    },
    "icons": {
        "128": "images/eye_open.png"
    },
    "action": {
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "/assets/js/contentScript.js"
            ]
        }
    ]
}
